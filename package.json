{
  "name": "deerflow-agent-framework",
  "version": "1.0.0",
  "description": "The Universal AI Agent Coding Standard Framework — rigorous quality enforcement for every AI coding agent, not limited to any specific one.",
  "main": "deerflow/core/index.js",
  "types": "deerflow/core/index.ts",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "validate": "bash scripts/validate.sh",
    "install-hooks": "bash scripts/install-hooks.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "build": "tsc",
    "lint": "eslint deerflow/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "quality:all": "npm run typecheck && npm run lint && npm run test:coverage && npm run validate"
  },
  "keywords": [
    "ai-agent",
    "coding-standards",
    "quality-gates",
    "cursor",
    "claude-code",
    "windsurf",
    "copilot",
    "cline",
    "aider",
    "continue",
    "devin",
    "deerflow",
    "agentic-workflow",
    "mcp",
    "coding-standards",
    "quality-gates",
    "zero-mock",
    "constraint-engine",
    "framework",
    "ai-coding",
    "agent-framework"
  ],
  "author": "Deerflow Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ntd25022006q/deerflow-agent---framework.git"
  },
  "bugs": {
    "url": "https://github.com/ntd25022006q/deerflow-agent---framework/issues"
  }
}
